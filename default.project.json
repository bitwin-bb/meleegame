{
  "name": "AquariaBackup",
  "globIgnorePaths": [
    "**/.package-lock.json",
    "**/.pnpm",
    "**/.pnpm-workspace-state-v1.json",
    "**/.modules.yaml",
    "**/.ignored",
    "**/.ignored_*"
  ],
  "tree": {
    "$className": "DataModel",
    "Workspace": {
      "$properties": {
        "FallHeightEnabled": false,
        "FallenPartsDestroyHeight": -50000
      }
    },
    "ReplicatedStorage": {
      "Packages": {
        "$path": "Packages"
      }
    },
    "ServerScriptService": {
      "ServerPackages": {
        "$path": "ServerPackages"
      },
      "AquariaBackup": {
        "$className": "Folder",
        "game": {
          "$path": "src/modules"
        },
        "node_modules": {
          "$path": "node_modules"
        }
      },
      "AquariaBackupScripts": {
        "$path": "src/scripts/Server"
      }
    },
    "StarterPlayer": {
      "StarterPlayerScripts": {
        "AquariaBackupScripts": {
          "$path": "src/scripts/Client"
        }
      }
    }
  }
}
